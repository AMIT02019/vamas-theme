{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

{% comment %} ── Collection Hero ──────────────────── {% endcomment %}
<section class="vamas-collection-hero">
  <div class="vamas-collection-hero__left">
    <div class="vamas-collection-hero__breadcrumb">
      <a href="/">{{ section.settings.breadcrumb_home | default: 'Home' }}</a>
      <span>&#8250;</span>
      <span>{{ collection.title | default: section.settings.fallback_title }}</span>
    </div>
    <h1 class="vamas-collection-hero__title">{{ collection.title | default: section.settings.fallback_title }}</h1>
    <p class="vamas-collection-hero__sub">{{ collection.description | strip_html | default: section.settings.fallback_sub }}</p>
  </div>
  <div class="vamas-collection-hero__right">
    <svg width="320" height="200" viewBox="0 0 320 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="80" cy="100" rx="40" ry="60" stroke="#e7d1a6" stroke-width="1.5" fill="none" transform="rotate(-20 80 100)"/>
      <circle cx="160" cy="110" r="18" stroke="#e7d1a6" stroke-width="1.2" fill="none" opacity=".5"/>
      <ellipse cx="200" cy="80" rx="35" ry="52" stroke="#e7d1a6" stroke-width="1.5" fill="none" transform="rotate(15 200 80)"/>
    </svg>
  </div>
</section>

{% comment %} ── Mobile filter bar (visual only — real filtering is not wired, see note in schema) ── {% endcomment %}
{% if section.settings.show_filters %}
<div class="vamas-collection-mob-filter-bar">
  <button class="vamas-collection-mob-filter-btn" id="vamas-mob-filter-btn" type="button">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
    {{ section.settings.filters_label | default: 'Filters' }}
  </button>
</div>
{% endif %}

<div class="vamas-collection-body">

  {% comment %} ── Filter sidebar (static/presentational markup — collection.html's filters
       are client-side-only over a hardcoded array with no server logic, so per the
       project brief this is preserved visually without real Shopify filter wiring) ── {% endcomment %}
  {% if section.settings.show_filters %}
  <aside class="vamas-collection-sidebar" id="vamas-collection-sidebar">
    <div class="vamas-collection-sidebar__head">
      <h3>{{ section.settings.filters_heading | default: 'FILTERS' }}</h3>
      <span class="vamas-collection-clear-all">{{ section.settings.clear_all_text | default: 'Clear All' }}</span>
    </div>

    {% for block in section.blocks %}
      {% if block.type == 'filter_group' %}
        <div class="vamas-collection-acc-item" {{ block.shopify_attributes }}>
          <div class="vamas-collection-acc-head open">
            <span>{{ block.settings.title }}</span>
            <span class="vamas-collection-acc-arrow">-</span>
          </div>
          <div class="vamas-collection-acc-body open">
            {% assign options = block.settings.options | split: ',' %}
            {% for option in options %}
              <label class="vamas-collection-check-row"><input type="checkbox">{{ option | strip }}</label>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

    <div class="vamas-collection-sidebar__apply">
      <button class="vamas-collection-apply-btn" type="button">{{ section.settings.apply_text | default: 'APPLY FILTERS' }}</button>
    </div>
  </aside>
  {% endif %}

  {% comment %} ── Products area ── {% endcomment %}
  <div class="vamas-collection-prod-area">

    {% paginate collection.products by section.settings.products_per_page %}
    <div class="vamas-collection-topbar">
      <div class="vamas-collection-count">
        {{ section.settings.showing_text | default: 'Showing' }}
        <strong>{{ paginate.current_offset | plus: 1 }}-{{ paginate.current_offset | plus: paginate.page_size | at_most: collection.products_count }}</strong>
        {{ section.settings.of_text | default: 'of' }}
        <strong>{{ collection.products_count }}</strong> {{ section.settings.products_text | default: 'products' }}
      </div>
      <div class="vamas-collection-sort-wrap">
        <span class="vamas-collection-sort-label">{{ section.settings.sort_label | default: 'SORT BY' }}</span>
        <form method="get" action="{{ collection.url }}">
          <select class="vamas-collection-sort-sel" name="sort_by" onchange="this.form.submit()">
            <option value="manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>{{ section.settings.sort_featured | default: 'Featured' }}</option>
            <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>{{ section.settings.sort_price_low | default: 'Price: Low to High' }}</option>
            <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>{{ section.settings.sort_price_high | default: 'Price: High to Low' }}</option>
            <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>{{ section.settings.sort_newest | default: 'Newest' }}</option>
            <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>{{ section.settings.sort_bestselling | default: 'Bestselling' }}</option>
          </select>
        </form>
      </div>
      </div>
    </div>

      <div class="vamas-collection-prod-grid">
        {% if collection.products.size > 0 %}
          {% for product in collection.products %}
            {% render 'vamas-product-card', product: product %}
          {% endfor %}
        {% else %}
          {% for i in (1..8) %}
            {% render 'vamas-product-card-placeholder', index: i %}
          {% endfor %}
        {% endif %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="vamas-collection-pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="vamas-collection-page-btn">&#8249; {{ section.settings.prev_text | default: 'Previous' }}</a>
          {% else %}
            <span class="vamas-collection-page-btn vamas-collection-page-btn--disabled">&#8249; {{ section.settings.prev_text | default: 'Previous' }}</span>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" class="vamas-collection-page-btn">{{ part.title }}</a>
            {% else %}
              <span class="vamas-collection-page-btn {% if part.title == paginate.current_page %}active{% endif %}">{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="vamas-collection-page-btn">{{ section.settings.next_text | default: 'Next' }} &#8250;</a>
          {% else %}
            <span class="vamas-collection-page-btn vamas-collection-page-btn--disabled">{{ section.settings.next_text | default: 'Next' }} &#8250;</span>
          {% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

{% schema %}
{
  "name": "Vamas Collection",
  "settings": [
    { "type": "text", "id": "breadcrumb_home", "label": "Breadcrumb home label", "default": "Home" },
    { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "All Collections" },
    { "type": "text", "id": "fallback_sub", "label": "Fallback subtitle", "default": "500+ handcrafted designs celebrating Indian artistry" },
    { "type": "header", "content": "Filters (presentational — see note below)" },
    { "type": "paragraph", "content": "Filters render as static UI matching the original design. The static site's filters were client-side only with no backend, so no real Shopify collection filtering is wired here." },
    { "type": "checkbox", "id": "show_filters", "label": "Show filter sidebar", "default": true },
    { "type": "text", "id": "filters_label", "label": "Mobile filter button label", "default": "Filters" },
    { "type": "text", "id": "filters_heading", "label": "Sidebar heading", "default": "FILTERS" },
    { "type": "text", "id": "clear_all_text", "label": "Clear all text", "default": "Clear All" },
    { "type": "text", "id": "apply_text", "label": "Apply button text", "default": "APPLY FILTERS" },
    { "type": "header", "content": "Sort & count labels" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 4, "max": 48, "step": 4, "default": 12 },
    { "type": "text", "id": "showing_text", "label": "\"Showing\" text", "default": "Showing" },
    { "type": "text", "id": "of_text", "label": "\"of\" text", "default": "of" },
    { "type": "text", "id": "products_text", "label": "\"products\" text", "default": "products" },
    { "type": "text", "id": "sort_label", "label": "Sort label", "default": "SORT BY" },
    { "type": "text", "id": "sort_featured", "label": "Sort option: Featured", "default": "Featured" },
    { "type": "text", "id": "sort_price_low", "label": "Sort option: Price low-high", "default": "Price: Low to High" },
    { "type": "text", "id": "sort_price_high", "label": "Sort option: Price high-low", "default": "Price: High to Low" },
    { "type": "text", "id": "sort_newest", "label": "Sort option: Newest", "default": "Newest" },
    { "type": "text", "id": "sort_bestselling", "label": "Sort option: Bestselling", "default": "Bestselling" },
    { "type": "text", "id": "prev_text", "label": "Pagination: previous", "default": "Previous" },
    { "type": "text", "id": "next_text", "label": "Pagination: next", "default": "Next" }
  ],
  "blocks": [
    {
      "type": "filter_group",
      "name": "Filter Group",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "OCCASION" },
        { "type": "text", "id": "options", "label": "Options (comma separated)", "default": "Bridal, Festive, Casual, Party Wear" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vamas Collection",
      "blocks": [
        { "type": "filter_group", "settings": { "title": "OCCASION", "options": "Bridal, Festive, Casual, Party Wear" } },
        { "type": "filter_group", "settings": { "title": "FABRIC", "options": "Silk, Cotton, Velvet, Georgette, Banarasi" } }
      ]
    }
  ]
}
{% endschema %}
