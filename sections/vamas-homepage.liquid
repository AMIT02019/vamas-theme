{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

<!-- Hero Slider -->
<div class="slider-wrap">
  <div class="slider-track" id="track">
    {% for block in section.blocks %}
      {% if block.type == 'slide' %}
      <div class="slide" style="background:{{ block.settings.slide_bg }};--slide-bg:{{ block.settings.slide_bg }};">
        <div class="slide-text">
          <p class="slide-eye">{{ block.settings.eyebrow }}</p>
          <h1 class="slide-h1">{{ block.settings.line1 }}<br><em>{{ block.settings.line2_accent }}</em><br>{{ block.settings.line3 }}</h1>
          <p class="slide-p">{{ block.settings.subtext }}</p>
          <div class="slide-btns">
            <a href="{{ block.settings.btn1_url }}" class="btn-p">{{ block.settings.btn1_text }}</a>
            <a href="{{ block.settings.btn2_url }}" class="btn-o">{{ block.settings.btn2_text }}</a>
          </div>
        </div>
        <div class="slide-img">
          {% if block.settings.slide_image != blank %}
            <img src="{{ block.settings.slide_image | img_url: 'master' }}" alt="{{ block.settings.line1 }}">
          {% else %}
            {% if forloop.index == 1 %}
              <img src="{{ 'slide-pink.jpg' | asset_url }}" alt="{{ block.settings.line1 }}">
            {% elsif forloop.index == 2 %}
              <img src="{{ 'slide-maroon.jpg' | asset_url }}" alt="{{ block.settings.line1 }}">
            {% else %}
              <img src="{{ 'slide-green.jpg' | asset_url }}" alt="{{ block.settings.line1 }}">
            {% endif %}
          {% endif %}
        </div>
      </div>
      {% endif %}
    {% endfor %}
  </div>

  <button class="sarrow sarrow-l" id="prev">&#8592;</button>
  <button class="sarrow sarrow-r" id="next">&#8594;</button>
  <div class="slider-dots">
    {% assign idx = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'slide' %}
        <button class="dot {% if idx == 0 %}active{% endif %}" data-i="{{ idx }}"></button>
        {% assign idx = idx | plus: 1 %}
      {% endif %}
    {% endfor %}
  </div>
</div>

<!-- Trust Bar -->
<div class="trust">
  <div class="trust-item">
    <div class="trust-icon"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
    <div><div class="trust-title">100% Authentic</div><div class="trust-sub">Genuine handcrafted fabric</div></div>
  </div>
  <div class="trust-item">
    <div class="trust-icon"><svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
    <div><div class="trust-title">Fast Delivery</div><div class="trust-sub">3-5 business days</div></div>
  </div>
  <div class="trust-item">
    <div class="trust-icon"><svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg></div>
    <div><div class="trust-title">Easy Returns</div><div class="trust-sub">7-day hassle-free</div></div>
  </div>
  <div class="trust-item">
    <div class="trust-icon"><svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
    <div><div class="trust-title">Secure Payment</div><div class="trust-sub">UPI &middot; Card &middot; COD</div></div>
  </div>
</div>

<!-- Shop by Occasion -->
<div class="sec">
  <div class="sec-hdr">
    <div><div class="sec-title">Shop by <span>Occasion</span></div><div class="sec-sub">Find the perfect blouse for every moment</div></div>
    <a href="/collections/all" class="view-all">VIEW ALL</a>
  </div>
  <div class="cat-grid">
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
      <a href="{{ block.settings.cat_url }}" class="cat-card">
        {% if block.settings.cat_image != blank %}
          <img src="{{ block.settings.cat_image | img_url: '400x533', crop: 'center' }}" alt="{{ block.settings.cat_name }}">
        {% else %}
          {% if block.settings.cat_name == 'BRIDAL' %}
            <img src="{{ 'Bridal.jpg' | asset_url }}" alt="{{ block.settings.cat_name }}">
          {% elsif block.settings.cat_name == 'FESTIVE' %}
            <img src="{{ 'Festive.jpg' | asset_url }}" alt="{{ block.settings.cat_name }}">
          {% elsif block.settings.cat_name == 'CASUAL' %}
            <img src="{{ 'Casual.JPG' | asset_url }}" alt="{{ block.settings.cat_name }}">
          {% else %}
            <img src="{{ 'party wear.jpg' | asset_url }}" alt="{{ block.settings.cat_name }}">
          {% endif %}
        {% endif %}
        <div class="cat-overlay"><div><div class="cat-label">{{ block.settings.cat_name }}</div><div class="cat-count">{{ block.settings.cat_count }}</div></div></div>
      </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

<!-- Full Look Banner -->
<div class="full-banner">
  {% if section.settings.full_banner_image != blank %}
    <img src="{{ section.settings.full_banner_image | img_url: 'master' }}" alt="Full Look">
  {% else %}
    <img src="{{ 'fulllook.webp' | asset_url }}" alt="Full Look">
  {% endif %}
</div>

<!-- New Arrivals -->
<div class="sec sec-alt">
  <div class="sec-hdr">
    <div><div class="sec-title">New <span>Arrivals</span></div><div class="sec-sub">Fresh styles added every week</div></div>
    <a href="/collections/all" class="view-all">VIEW ALL</a>
  </div>
  <div class="prod-grid">
    {% assign na_col = collections[section.settings.new_arrivals_collection] %}
    {% for product in na_col.products limit: 3 %}
      {% render 'vamas-product-card', product: product %}
    {% else %}
      {% for i in (1..3) %}{% render 'vamas-product-card-placeholder', index: i %}{% endfor %}
    {% endfor %}
  </div>
</div>

<!-- Brand Story -->
<div class="brand-sec">
  <div class="brand-text">
    <div class="brand-eye">OUR STORY</div>
    <div class="brand-h2">Woven with Love,<br>Crafted with Precision</div>
    <div class="brand-p">Each blouse is handcrafted by skilled artisans using premium fabrics sourced across India. From bridal zari to everyday cotton, we celebrate the art of Indian craftsmanship - one thread at a time.</div>
    <div class="brand-stats">
      <div><div class="stat-num">500+</div><div class="stat-lbl">DESIGNS</div></div>
      <div><div class="stat-num">10K+</div><div class="stat-lbl">CUSTOMERS</div></div>
      <div><div class="stat-num">4.9&#9733;</div><div class="stat-lbl">RATING</div></div>
    </div>
    <a href="/pages/about" class="btn-o" style="display:inline-block;">EXPLORE OUR STORY</a>
  </div>
  <div class="brand-img">
    {% if section.settings.brand_image != blank %}
      <img src="{{ section.settings.brand_image | img_url: 'master' }}" alt="Brand Image">
    {% else %}
      <img src="{{ 'Full look.jpg' | asset_url }}" alt="Brand Image">
    {% endif %}
  </div>
</div>

<!-- Best Sellers -->
<div class="sec">
  <div class="sec-hdr">
    <div><div class="sec-title">Best <span>Sellers</span></div><div class="sec-sub">Most loved by our customers</div></div>
    <a href="/collections/all" class="view-all">VIEW ALL</a>
  </div>
  <div class="prod-grid">
    {% assign bs_col = collections[section.settings.bestsellers_collection] %}
    {% for product in bs_col.products limit: 3 %}
      {% render 'vamas-product-card', product: product %}
    {% else %}
      {% for i in (4..6) %}{% render 'vamas-product-card-placeholder', index: i %}{% endfor %}
    {% endfor %}
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const track = document.getElementById('track');
  const slides = document.querySelectorAll('.slide');
  const next = document.getElementById('next');
  const prev = document.getElementById('prev');
  const dots = document.querySelectorAll('.dot');
  
  if(!track || slides.length === 0) return;
  let index = 0;

  function updateSlider() {
    track.style.transform = 'translateX(-' + (index * 100) + '%)';
    dots.forEach(d => d.classList.remove('active'));
    if(dots[index]) dots[index].classList.add('active');
  }

  if(next) next.addEventListener('click', () => { index = (index + 1) % slides.length; updateSlider(); });
  if(prev) prev.addEventListener('click', () => { index = (index - 1 + slides.length) % slides.length; updateSlider(); });
  dots.forEach((dot, i) => { dot.addEventListener('click', () => { index = i; updateSlider(); }); });
  setInterval(() => { index = (index + 1) % slides.length; updateSlider(); }, 5000);
});
</script>

{% schema %}
{
  "name": "Vamas Homepage",
  "settings": [
    { "type": "image_picker", "id": "full_banner_image", "label": "Full Look Banner Image" },
    { "type": "collection", "id": "new_arrivals_collection", "label": "New Arrivals Collection" },
    { "type": "collection", "id": "bestsellers_collection", "label": "Best Sellers Collection" },
    { "type": "image_picker", "id": "brand_image", "label": "Brand Image" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero Slide",
      "settings": [
        { "type": "color", "id": "slide_bg", "label": "Background Color", "default": "#420001" },
        { "type": "image_picker", "id": "slide_image", "label": "Blouse Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "NEW COLLECTION 2026" },
        { "type": "text", "id": "line1", "label": "Heading Line 1", "default": "Craft Your" },
        { "type": "text", "id": "line2_accent", "label": "Heading Accent", "default": "Perfect" },
        { "type": "text", "id": "line3", "label": "Heading Line 3", "default": "Silhouette" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "Handcrafted blouses that celebrate every occasion with elegance & grace." },
        { "type": "text", "id": "btn1_text", "label": "Primary Button", "default": "SHOP NOW" },
        { "type": "url", "id": "btn1_url", "label": "Primary Button URL" },
        { "type": "text", "id": "btn2_text", "label": "Secondary Button", "default": "VIEW LOOKBOOK" },
        { "type": "url", "id": "btn2_url", "label": "Secondary Button URL" }
      ]
    },
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "cat_image", "label": "Category Image" },
        { "type": "text", "id": "cat_name", "label": "Name", "default": "BRIDAL" },
        { "type": "text", "id": "cat_count", "label": "Style Count", "default": "120+ styles" },
        { "type": "url", "id": "cat_url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    { "name": "Vamas Homepage" }
  ]
}
{% endschema %}
