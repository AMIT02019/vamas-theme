<div class="dark-bottom">
  <div class="dark-nl">
    <div class="dark-nl-eye">EXCLUSIVE UPDATES</div>
    <div class="dark-nl-h3">Stay in <em>style.</em></div>
    <div class="dark-nl-sub">Subscribe for new arrivals, exclusive offers &amp; style inspiration</div>
    {% form 'customer', class: 'dark-nl-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" class="dark-nl-input" placeholder="Enter your email address" required>
      <button type="submit" class="dark-nl-btn">SUBSCRIBE</button>
    {% endform %}
  </div>
  
  <footer class="dark-footer">
    <div class="dark-footer-grid">
      <div>
        <div class="dark-footer-logo">
          {% if section.settings.logo_image != blank %}
            <img src="{{ section.settings.logo_image | img_url: 'master' }}" alt="{{ shop.name }}" class="dark-footer-logo-img">
          {% else %}
            <img src="{{ 'vamas-logo.avif' | asset_url }}" alt="Vamas" class="dark-footer-logo-img" onerror="this.style.display='none'">
          {% endif %}
        </div>
        <p class="dark-footer-desc">{{ section.settings.description }}</p>
        <div class="dark-footer-socials">
          {% if settings.social_instagram_link != blank %}
          <a href="{{ settings.social_instagram_link }}" class="dark-soc"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
          {% endif %}
          {% if settings.social_facebook_link != blank %}
          <a href="{{ settings.social_facebook_link }}" class="dark-soc"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
          {% endif %}
        </div>
      </div>
      
      <div>
        <div class="dark-foot-head">{{ section.settings.linklist_1_title }}</div>
        <div class="dark-foot-links">
          {% for link in linklists[section.settings.linklist_1].links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </div>
      </div>
      
      <div>
        <div class="dark-foot-head">{{ section.settings.linklist_2_title }}</div>
        <div class="dark-foot-links">
          {% for link in linklists[section.settings.linklist_2].links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </div>
      </div>
      
      <div>
        <div class="dark-foot-head">CONTACT US</div>
        <div class="dark-foot-links">
          <a href="mailto:{{ shop.email }}">{{ shop.email }}</a>
          <a href="tel:{{ shop.phone }}">{{ shop.phone }}</a>
          <span style="color:rgba(231,209,166,.3);font-size:10px;">Mon-Sat: 10am - 6pm</span>
        </div>
      </div>
    </div>
    
    <div class="dark-footer-bot">
      <div class="dark-foot-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</div>
      <div class="dark-foot-pay">UPI &nbsp;&middot;&nbsp; Visa &nbsp;&middot;&nbsp; Mastercard &nbsp;&middot;&nbsp; Net Banking &nbsp;&middot;&nbsp; COD</div>
    </div>
  </footer>
</div>

{% schema %}
{
  "name": "Vamas Footer",
  "settings": [
    { "type": "image_picker", "id": "logo_image", "label": "Footer Logo" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Premium handcrafted blouses celebrating Indian artistry. Every piece tells a story woven with love and skill." },
    { "type": "text", "id": "linklist_1_title", "label": "Menu 1 Title", "default": "QUICK LINKS" },
    { "type": "link_list", "id": "linklist_1", "label": "Menu 1" },
    { "type": "text", "id": "linklist_2_title", "label": "Menu 2 Title", "default": "CUSTOMER CARE" },
    { "type": "link_list", "id": "linklist_2", "label": "Menu 2" }
  ],
  "presets": [
    { "name": "Vamas Footer" }
  ]
}
{% endschema %}
