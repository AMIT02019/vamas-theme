{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

<section class="vamas-404">
  <div class="vamas-404__code">{{ section.settings.code | default: '404' }}</div>
  <h1 class="vamas-404__heading">{{ section.settings.heading | default: 'Page Not Found' }}</h1>
  <p class="vamas-404__subtext">{{ section.settings.subtext | default: "The page you're looking for doesn't exist or has been moved." }}</p>
  <div class="vamas-404__actions">
    <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn-primary">{{ section.settings.button_text | default: 'Continue Shopping' }}</a>
    <a href="/" class="btn-outline">{{ section.settings.home_text | default: 'Back to Home' }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Vamas 404",
  "settings": [
    { "type": "text", "id": "code", "label": "Code", "default": "404" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page Not Found" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "The page you're looking for doesn't exist or has been moved." },
    { "type": "text", "id": "button_text", "label": "Primary button text", "default": "Continue Shopping" },
    { "type": "url", "id": "button_url", "label": "Primary button URL" },
    { "type": "text", "id": "home_text", "label": "Secondary button text", "default": "Back to Home" }
  ],
  "presets": [{ "name": "Vamas 404" }]
}
{% endschema %}
