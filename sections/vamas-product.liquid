{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

{% comment %} ── Breadcrumb ───────────────────────── {% endcomment %}
<div class="vamas-product-breadcrumb">
  <a href="/">{{ section.settings.breadcrumb_home | default: 'Home' }}</a>
  <span>&#8250;</span>
  <a href="/collections/all">{{ section.settings.breadcrumb_collections | default: 'Collections' }}</a>
  <span>&#8250;</span>
  <span>{{ product.title }}</span>
</div>

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign on_sale = false %}
{% if current_variant.compare_at_price > current_variant.price %}{% assign on_sale = true %}{% endif %}
{% assign discount_pct = 0 %}
{% if on_sale %}
  {% assign diff = current_variant.compare_at_price | minus: current_variant.price %}
  {% assign discount_pct = diff | times: 100 | divided_by: current_variant.compare_at_price | round %}
{% endif %}
{% assign color_option_index = -1 %}
{% for option in product.options_with_values %}
  {% if option.name == 'Color' or option.name == 'Colour' %}{% assign color_option_index = forloop.index0 %}{% endif %}
{% endfor %}

<section class="vamas-product-section">

  {% comment %} ── Gallery ── {% endcomment %}
  <div class="vamas-product-gallery">
    <div class="vamas-product-gallery__main" id="vamas-gallery-main">
      {% if product.featured_media %}
        <img id="vamas-main-img" src="{{ product.featured_media | img_url: '800x960', crop: 'center' }}"
             alt="{{ product.featured_media.alt | escape | default: product.title }}" width="800" height="960">
      {% else %}
        {{ 'model-1' | placeholder_svg_tag: 'placeholder-svg vamas-product-gallery__placeholder' }}
      {% endif %}
      {% if section.settings.gallery_badge != blank %}
        <div class="vamas-product-gallery__badge">{{ section.settings.gallery_badge }}</div>
      {% endif %}
      {% if product.media.size > 1 %}
        <button class="vamas-product-gal-arrow vamas-product-gal-arrow--l" id="vamas-gal-prev" aria-label="Previous image">&#8249;</button>
        <button class="vamas-product-gal-arrow vamas-product-gal-arrow--r" id="vamas-gal-next" aria-label="Next image">&#8250;</button>
      {% endif %}
      <div class="vamas-product-zoom-hint">&#128269; {{ section.settings.zoom_hint_text | default: 'Click to zoom' }}</div>
    </div>
    {% if product.media.size > 1 %}
      <div class="vamas-product-thumb-strip" id="vamas-thumb-strip">
        {% for media in product.media %}
          <div class="vamas-product-thumb-item {% if forloop.first %}active{% endif %}" data-idx="{{ forloop.index0 }}" data-full="{{ media | img_url: '800x960', crop: 'center' }}">
            <img src="{{ media | img_url: '160x192', crop: 'center' }}" alt="{{ media.alt | escape | default: product.title }}" loading="lazy" width="96" height="116">
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {% comment %} ── Product Info ── {% endcomment %}
  <div class="vamas-product-info">

    <div class="vamas-product-badge-row">
      {% if section.settings.badge_new_text != blank %}<span class="vamas-product-badge">{{ section.settings.badge_new_text }}</span>{% endif %}
      {% if section.settings.badge_hot_text != blank %}<span class="vamas-product-badge vamas-product-badge--hot">{{ section.settings.badge_hot_text }}</span>{% endif %}
    </div>

    <h1 class="vamas-product-name">{{ product.title }}</h1>
    <div class="vamas-product-type">{{ product.type | default: section.settings.default_type }}</div>

    <div class="vamas-product-rating">
      {% if product.metafields.reviews.rating.value %}
        {% assign rating_val = product.metafields.reviews.rating.value.rating | floor %}
        <span class="vamas-product-stars">{% for i in (1..5) %}{% if i <= rating_val %}&#9733;{% else %}&#9734;{% endif %}{% endfor %}</span>
        <span class="vamas-product-rating-num">{{ product.metafields.reviews.rating.value.rating }}</span>
        <span class="vamas-product-rating-count">({{ product.metafields.reviews.rating_count.value | default: 0 }} {{ section.settings.reviews_label | default: 'reviews' }})</span>
      {% else %}
        <span class="vamas-product-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="vamas-product-rating-num">4.9</span>
        <span class="vamas-product-rating-count">({{ product.id | modulo: 100 | plus: 24 }} {{ section.settings.reviews_label | default: 'reviews' }})</span>
      {% endif %}
      <span class="vamas-product-rating-sold">| {{ section.settings.sold_count | default: 847 }} {{ section.settings.sold_label | default: 'sold' }}</span>
      <a href="#vamas-reviews" class="vamas-product-rating-link">{{ section.settings.read_reviews_text | default: 'Read reviews ↓' }}</a>
    </div>

    <div class="vamas-product-price">
      <span class="vamas-product-price__now">{{ current_variant.price | money }}</span>
      {% if on_sale %}
        <span class="vamas-product-price__old">{{ current_variant.compare_at_price | money }}</span>
        <span class="vamas-product-price__off">{{ discount_pct }}% {{ section.settings.off_label | default: 'off' }}</span>
      {% endif %}
    </div>
    {% if section.settings.emi_note != blank %}<div class="vamas-product-emi-note">{{ section.settings.emi_note }}</div>{% endif %}

    {% if section.settings.offer_code != blank %}
      <div class="vamas-product-offer-strip">
        <span class="vamas-product-offer-tag">{{ section.settings.offer_tag | default: 'OFFER' }}</span>
        <span class="vamas-product-offer-text">{{ section.settings.offer_text | default: 'Use code' }}
          <span class="vamas-product-offer-code" id="vamas-coupon-code" title="Click to copy">{{ section.settings.offer_code }}</span>
          {{ section.settings.offer_text_2 | default: 'for 10% off on your first order' }}
        </span>
        <span class="vamas-product-offer-copied" id="vamas-offer-copied">{{ section.settings.copied_text | default: 'Copied!' }}</span>
      </div>
    {% endif %}

    {% if section.settings.show_social_proof %}
      <div class="vamas-product-social-proof">
        <span class="vamas-product-social-dot"></span>
        <span id="vamas-viewer-count">{{ section.settings.viewer_count | default: 18 }}</span> {{ section.settings.social_proof_text | default: 'people are viewing this right now' }}
      </div>
    {% endif %}

    <div class="vamas-product-divider"></div>

    {% form 'product', product, id: 'vamas-product-form', class: 'vamas-product-form' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}" id="vamas-selected-variant-id">

      {% comment %} Variant option selectors ── {% endcomment %}
      {% for option in product.options_with_values %}
        <div class="vamas-product-option {% if forloop.index0 == color_option_index %}vamas-product-option--color{% endif %}">
          <div class="vamas-product-option__label">{{ option.name | upcase }}</div>
          {% if forloop.index0 == color_option_index %}
            <div class="vamas-product-swatches">
              {% for value in option.values %}
                <div class="vamas-product-swatch {% if value == option.selected_value %}active{% endif %}"
                     style="background: {{ value | handleize | replace: '-', '' }};"
                     data-option-index="{{ forloop.parent.index0 }}" data-value="{{ value | escape }}"
                     title="{{ value }}"></div>
              {% endfor %}
            </div>
            <div class="vamas-product-color-name">{{ option.name }}: <strong>{{ option.selected_value }}</strong></div>
          {% else %}
            <div class="vamas-product-pills">
              {% for value in option.values %}
                <button type="button" class="vamas-product-pill {% if value == option.selected_value %}active{% endif %}"
                        data-option-index="{{ forloop.parent.index0 }}" data-value="{{ value | escape }}">{{ value }}</button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}

      {% if section.settings.custom_note != blank %}
        <div class="vamas-product-custom-note">&#9986; {{ section.settings.custom_note }}</div>
      {% endif %}

      {% if section.settings.show_delivery_box %}
        <div class="vamas-product-delivery-box">
          <div class="vamas-product-delivery-row"><span class="vamas-product-d-icon">&#128666;</span><span>{{ section.settings.delivery_line1 | default: 'Free delivery on orders above ₹999' }}</span></div>
          <div class="vamas-product-delivery-row"><span class="vamas-product-d-icon">&#128197;</span><span>{{ section.settings.delivery_line2 | default: 'Order now — estimated delivery in 3-5 business days' }}</span></div>
          <div class="vamas-product-delivery-row"><span class="vamas-product-d-icon">&#8635;</span><span>{{ section.settings.delivery_line3 | default: '7-day easy returns on standard sizes' }}</span></div>
          <div class="vamas-product-pincode-form">
            <input class="vamas-product-pincode-input" id="vamas-pincode-input" type="text" maxlength="6" placeholder="{{ section.settings.pincode_placeholder | default: 'Enter pincode to check delivery' }}">
            <button class="vamas-product-pincode-btn" type="button" id="vamas-pincode-btn">{{ section.settings.pincode_btn_text | default: 'CHECK' }}</button>
          </div>
          <div class="vamas-product-pincode-result" id="vamas-pincode-result"></div>
        </div>
      {% endif %}

      <div class="vamas-product-qty-row">
        <span class="vamas-product-qty-label">{{ section.settings.qty_label | default: 'QUANTITY' }}</span>
        <div class="vamas-product-qty-control">
          <button type="button" class="vamas-product-qty-btn" id="vamas-qty-minus">&#8722;</button>
          <input type="number" class="vamas-product-qty-num" name="quantity" id="vamas-qty-num" value="1" min="1" max="10">
          <button type="button" class="vamas-product-qty-btn" id="vamas-qty-plus">&#43;</button>
        </div>
      </div>

      {% if current_variant.available %}
        <button type="submit" class="vamas-atc vamas-product-btn-atc" id="vamas-product-atc-btn" data-product-id="{{ product.id }}">{{ section.settings.atc_text | default: 'ADD TO CART' }}</button>
      {% else %}
        <button type="button" class="vamas-atc vamas-product-btn-atc" disabled style="opacity:.5;cursor:not-allowed;">{{ section.settings.sold_out_text | default: 'SOLD OUT' }}</button>
      {% endif %}
      {% if section.settings.show_buy_now %}
        <button type="button" class="vamas-product-btn-buy" id="vamas-product-buy-btn">&#9889; {{ section.settings.buy_now_text | default: 'BUY NOW' }}</button>
      {% endif %}
    {% endform %}

    {% if section.settings.show_payment_strip %}
      <div class="vamas-product-payment-strip">
        {% assign pay_methods = section.settings.payment_methods | default: 'UPI, Visa, Mastercard, Net Banking, COD' | split: ',' %}
        {% for method in pay_methods %}<span class="vamas-product-pay-badge">{{ method | strip }}</span>{% endfor %}
      </div>
    {% endif %}

    <button type="button" class="vamas-product-wishlist-link" data-wishlist-toggle data-product-id="{{ product.id }}">&#9825; {{ section.settings.wishlist_text | default: 'Add to Wishlist' }}</button>

    {% if section.settings.show_share %}
      <div class="vamas-product-share-row">
        <span class="vamas-product-share-label">{{ section.settings.share_label | default: 'Share:' }}</span>
        <button class="vamas-product-share-btn" id="vamas-share-wa" type="button" title="Share on WhatsApp" data-url="{{ shop.url }}{{ product.url }}" data-title="{{ product.title | escape }}">
          <svg width="16" height="16" viewBox="0 0 32 32" fill="#25D366"><path d="M16 3C8.832 3 3 8.832 3 16c0 2.625.77 5.074 2.086 7.129L3.05 28.855 9 26.875C10.973 28.023 13.41 29 16 29c7.168 0 13-5.832 13-13S23.168 3 16 3zm0 2c6.086 0 11 4.914 11 11s-4.914 11-11 11c-2.324 0-4.48-.766-6.25-2.063l-.399-.297-3.586.945.992-2.843-.334-.426A10.945 10.945 0 0 1 5 16C5 9.914 9.914 5 16 5z"/></svg>
        </button>
        <button class="vamas-product-share-btn" id="vamas-share-copy" type="button" title="Copy link">&#128279;</button>
      </div>
    {% endif %}

    {% assign trust_blocks = section.blocks | where: 'type', 'trust_badge' %}
    {% if trust_blocks.size > 0 %}
      <div class="vamas-product-trust-grid">
        {% for block in section.blocks %}
          {% if block.type == 'trust_badge' %}
            <div class="vamas-product-trust-item" {{ block.shopify_attributes }}><span class="vamas-product-trust-icon">{{ block.settings.icon | default: '✓' }}</span><span>{{ block.settings.label }}</span></div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% comment %} ── Description ── {% endcomment %}
    {% if product.description != blank %}
      <div class="vamas-product-description">{{ product.description }}</div>
    {% endif %}

    {% comment %} ── Accordion (info blocks) ── {% endcomment %}
    {% assign acc_blocks = section.blocks | where: 'type', 'accordion_item' %}
    {% if acc_blocks.size > 0 %}
      <div class="vamas-product-accordion">
        {% for block in section.blocks %}
          {% if block.type == 'accordion_item' %}
            <details class="vamas-product-acc-item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
              <summary class="vamas-product-acc-header">{{ block.settings.title }}<span class="vamas-product-acc-icon">+</span></summary>
              <div class="vamas-product-acc-content">{{ block.settings.content }}</div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% comment %} ── Reviews ── {% endcomment %}
{% assign review_blocks = section.blocks | where: 'type', 'review' %}
{% if section.settings.show_reviews and review_blocks.size > 0 %}
<section class="vamas-product-reviews" id="vamas-reviews">
  <h2 class="vamas-product-reviews__heading">{{ section.settings.reviews_heading | default: 'Customer Reviews' }}</h2>
  <div class="vamas-product-reviews__grid">
    <div class="vamas-product-reviews__summary">
      <div class="vamas-product-reviews__score">{{ section.settings.reviews_avg_score | default: '4.9' }}</div>
      <div class="vamas-product-reviews__stars-big">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <div class="vamas-product-reviews__count">{{ section.settings.reviews_based_on | default: 'Based on 124 reviews' }}</div>
    </div>
    <div class="vamas-product-reviews__cards">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="vamas-product-review-card" {{ block.shopify_attributes }}>
            <div class="vamas-product-review-card__top">
              <div><span class="vamas-product-review-card__name">{{ block.settings.reviewer_name }}</span>
                {% if block.settings.verified %}<span class="vamas-product-review-card__verified">&#10003; {{ section.settings.verified_text | default: 'Verified Purchase' }}</span>{% endif %}</div>
              <div><div class="vamas-product-review-card__stars">{% for i in (1..5) %}{% if i <= block.settings.rating %}&#9733;{% else %}&#9734;{% endif %}{% endfor %}</div>
                <div class="vamas-product-review-card__date">{{ block.settings.review_date }}</div></div>
            </div>
            <div class="vamas-product-review-card__title">{{ block.settings.review_title }}</div>
            <div class="vamas-product-review-card__text">{{ block.settings.review_text }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% comment %} ── Related products mount point (loaded via AJAX, see assets/theme.js) ── {% endcomment %}
{% if section.settings.show_related %}
<div id="vamas-related-products" data-product-id="{{ product.id }}" data-url="{{ routes.product_recommendations_url }}"></div>
{% endif %}

{% comment %} ── Sticky ATC bar ── {% endcomment %}
<div class="vamas-product-sticky-atc" id="vamas-sticky-atc">
  <div class="vamas-product-sticky-thumb">
    {% if product.featured_image %}<img src="{{ product.featured_image | img_url: '96x116', crop: 'center' }}" alt="{{ product.title | escape }}">{% endif %}
  </div>
  <div class="vamas-product-sticky-info">
    <div class="vamas-product-sticky-name">{{ product.title }}</div>
    <div class="vamas-product-sticky-price">{{ current_variant.price | money }}{% if on_sale %} <span class="vamas-product-sticky-old">{{ current_variant.compare_at_price | money }}</span>{% endif %}</div>
  </div>
  <button class="vamas-product-sticky-btn" id="vamas-sticky-atc-btn" data-variant-id="{{ current_variant.id }}">{{ section.settings.atc_text | default: 'ADD TO CART' }}</button>
</div>

<script>
  window.vamasProductVariants = {{ product.variants | json }};
</script>

{% schema %}
{
  "name": "Vamas Product",
  "settings": [
    { "type": "header", "content": "Breadcrumb" },
    { "type": "text", "id": "breadcrumb_home", "label": "Home label", "default": "Home" },
    { "type": "text", "id": "breadcrumb_collections", "label": "Collections label", "default": "Collections" },
    { "type": "header", "content": "Badges & Type" },
    { "type": "text", "id": "badge_new_text", "label": "Primary badge", "default": "NEW ARRIVAL" },
    { "type": "text", "id": "badge_hot_text", "label": "Secondary badge", "default": "🔥 TRENDING" },
    { "type": "text", "id": "gallery_badge", "label": "Gallery image badge", "default": "NEW ARRIVAL" },
    { "type": "text", "id": "default_type", "label": "Default product type", "default": "Blouse" },
    { "type": "text", "id": "zoom_hint_text", "label": "Zoom hint text", "default": "Click to zoom" },
    { "type": "header", "content": "Ratings" },
    { "type": "text", "id": "reviews_label", "label": "Reviews label", "default": "reviews" },
    { "type": "text", "id": "sold_count", "label": "Sold count", "default": "847" },
    { "type": "text", "id": "sold_label", "label": "Sold label", "default": "sold" },
    { "type": "text", "id": "read_reviews_text", "label": "Read reviews link text", "default": "Read reviews ↓" },
    { "type": "header", "content": "Pricing" },
    { "type": "text", "id": "off_label", "label": "Discount suffix", "default": "off" },
    { "type": "text", "id": "emi_note", "label": "EMI note", "default": "" },
    { "type": "header", "content": "Offer strip" },
    { "type": "text", "id": "offer_tag", "label": "Offer tag", "default": "OFFER" },
    { "type": "text", "id": "offer_text", "label": "Offer text (before code)", "default": "Use code" },
    { "type": "text", "id": "offer_code", "label": "Offer code", "default": "FIRST10" },
    { "type": "text", "id": "offer_text_2", "label": "Offer text (after code)", "default": "for 10% off on your first order" },
    { "type": "text", "id": "copied_text", "label": "Copied label", "default": "Copied!" },
    { "type": "header", "content": "Social proof" },
    { "type": "checkbox", "id": "show_social_proof", "label": "Show social proof line", "default": true },
    { "type": "text", "id": "viewer_count", "label": "Viewer count", "default": "18" },
    { "type": "text", "id": "social_proof_text", "label": "Social proof text", "default": "people are viewing this right now" },
    { "type": "header", "content": "Custom note & delivery" },
    { "type": "text", "id": "custom_note", "label": "Custom note", "default": "Free custom stitching available — just share your measurements at checkout" },
    { "type": "checkbox", "id": "show_delivery_box", "label": "Show delivery info box", "default": true },
    { "type": "text", "id": "delivery_line1", "label": "Delivery line 1", "default": "Free delivery on orders above ₹999" },
    { "type": "text", "id": "delivery_line2", "label": "Delivery line 2", "default": "Order now — estimated delivery in 3-5 business days" },
    { "type": "text", "id": "delivery_line3", "label": "Delivery line 3", "default": "7-day easy returns on standard sizes" },
    { "type": "text", "id": "pincode_placeholder", "label": "Pincode placeholder", "default": "Enter pincode to check delivery" },
    { "type": "text", "id": "pincode_btn_text", "label": "Pincode button text", "default": "CHECK" },
    { "type": "header", "content": "Buttons & labels" },
    { "type": "text", "id": "qty_label", "label": "Quantity label", "default": "QUANTITY" },
    { "type": "text", "id": "atc_text", "label": "Add to cart button text", "default": "ADD TO CART" },
    { "type": "text", "id": "sold_out_text", "label": "Sold out button text", "default": "SOLD OUT" },
    { "type": "checkbox", "id": "show_buy_now", "label": "Show Buy Now button", "default": true },
    { "type": "text", "id": "buy_now_text", "label": "Buy now button text", "default": "BUY NOW" },
    { "type": "text", "id": "wishlist_text", "label": "Wishlist link text", "default": "Add to Wishlist" },
    { "type": "checkbox", "id": "show_payment_strip", "label": "Show payment strip", "default": true },
    { "type": "text", "id": "payment_methods", "label": "Payment methods (comma separated)", "default": "UPI, Visa, Mastercard, Net Banking, COD" },
    { "type": "checkbox", "id": "show_share", "label": "Show share row", "default": true },
    { "type": "text", "id": "share_label", "label": "Share label", "default": "Share:" },
    { "type": "header", "content": "Reviews section" },
    { "type": "checkbox", "id": "show_reviews", "label": "Show reviews section", "default": true },
    { "type": "text", "id": "reviews_heading", "label": "Reviews heading", "default": "Customer Reviews" },
    { "type": "text", "id": "reviews_avg_score", "label": "Average score", "default": "4.9" },
    { "type": "text", "id": "reviews_based_on", "label": "Based-on text", "default": "Based on 124 reviews" },
    { "type": "text", "id": "verified_text", "label": "Verified purchase text", "default": "Verified Purchase" },
    { "type": "header", "content": "Related products" },
    { "type": "checkbox", "id": "show_related", "label": "Show related products", "default": true }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "✓" },
        { "type": "text", "id": "label", "label": "Label", "default": "100% Authentic Handcrafted" }
      ]
    },
    {
      "type": "accordion_item",
      "name": "Accordion Item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "PRODUCT DETAILS" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Fabric: 100% Banarasi Silk</p>" }
      ]
    },
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "reviewer_name", "label": "Reviewer name", "default": "Priya Sharma" },
        { "type": "checkbox", "id": "verified", "label": "Verified purchase", "default": true },
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "review_date", "label": "Date", "default": "Dec 2025" },
        { "type": "text", "id": "review_title", "label": "Review title", "default": "Absolutely Stunning!" },
        { "type": "textarea", "id": "review_text", "label": "Review text", "default": "The quality of this blouse is beyond my expectations." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vamas Product",
      "blocks": [
        { "type": "trust_badge", "settings": { "icon": "✓", "label": "100% Authentic Handcrafted" } },
