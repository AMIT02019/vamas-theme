{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}
<div class="breadcrumb">
  <a href="/">Home</a><span>&#8250;</span><span>My Cart</span>
</div>

<div class="cart-page-header">
  <div style="display:flex;align-items:center;">
    <span class="cart-page-title">My Cart</span>
    <span class="cart-count-badge" id="cart-count-badge">{{ cart.item_count }} items</span>
  </div>
  <a href="/collections/all" class="continue-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Continue Shopping
  </a>
</div>

{% if cart.item_count > 0 %}
<form action="/cart" method="post" id="cart-form" class="cart-layout">
  <div id="cart-left">
    <div class="free-del-box" id="free-del-box">
      <div class="fdel-top">
        {% assign free_shipping_threshold = 99900 %}
        {% if cart.total_price < free_shipping_threshold %}
          {% assign amount_needed = free_shipping_threshold | minus: cart.total_price %}
          <div class="fdel-label">Add <strong>{{ amount_needed | money }}</strong> more for free delivery!</div>
          <div class="fdel-track"><div class="fdel-fill" id="fdel-fill" style="width:{{ cart.total_price | times: 100 | divided_by: free_shipping_threshold }}%"></div></div>
        {% else %}
          <div class="fdel-label">&#127881; You've unlocked <strong>FREE delivery!</strong></div>
          <div class="fdel-track"><div class="fdel-fill" id="fdel-fill" style="width:100%"></div></div>
        {% endif %}
      </div>
    </div>

    <div class="cart-items-wrap" id="cart-items-wrap">
      <div class="cart-items-head">
        <div>PRODUCT</div><div>PRICE</div><div>QUANTITY</div><div style="text-align:right;">SUBTOTAL</div><div></div>
      </div>
      <div id="cart-items-body">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="ci-prod">
              <a href="{{ item.url }}"><img src="{{ item.image | img_url: '100x' }}" alt="{{ item.title | escape }}"></a>
              <div class="ci-details">
                <a href="{{ item.url }}" class="ci-title">{{ item.product.title }}</a>
                {% unless item.product.has_only_default_variant %}
                  <div class="ci-variant">{{ item.variant.title }}</div>
                {% endunless %}
              </div>
            </div>
            <div class="ci-price">{{ item.price | money }}</div>
            <div class="ci-qty">
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="ci-qty-input" aria-label="Quantity for {{ item.title | escape }}">
            </div>
            <div class="ci-subtotal" style="text-align:right; font-weight: 500;">
              {{ item.line_price | money }}
            </div>
            <div class="ci-remove">
              <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="ci-remove-btn" title="Remove">&#10005;</a>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
    
    <div style="margin-top:20px;text-align:right;">
      <button type="submit" name="update" class="btn-update" style="padding: 10px 20px; background: #eee; border: none; cursor: pointer; border-radius: 4px; font-weight: 500;">Update Cart</button>
    </div>
  </div>

  <div class="order-summary" id="order-summary-panel">
    <div class="os-title">ORDER SUMMARY</div>

    <div class="os-row"><span>MRP Total (<span id="os-item-count">{{ cart.item_count }} items</span>)</span><span id="os-mrp">{{ cart.original_total_price | money }}</span></div>
    
    {% if cart.total_discount > 0 %}
      <div class="os-row green"><span>Discounts</span><span id="os-discount">− {{ cart.total_discount | money }}</span></div>
    {% endif %}
    
    <div class="os-row">
      <span>Delivery Charges</span>
      <span id="os-delivery">{% if cart.total_price >= 99900 %}FREE{% else %}Calculated at checkout{% endif %}</span>
    </div>
    <div class="os-divider"></div>
    <div class="os-total"><span>TOTAL PAYABLE</span><span id="os-total">{{ cart.total_price | money }}</span></div>

    <button type="submit" name="checkout" class="btn-checkout">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      PROCEED TO CHECKOUT
    </button>
    <button type="button" class="btn-continue" onclick="window.location.href='/collections/all'">Continue Shopping</button>

    <div class="trust-mini">
      <div class="tm-item"><svg class="tm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>100% Secure Checkout</div>
      <div class="tm-item"><svg class="tm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg>7-Day Easy Returns</div>
      <div class="tm-item"><svg class="tm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>Ships in 2–3 Business Days</div>
      <div class="tm-item"><svg class="tm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Handcrafted &amp; Authentic</div>
    </div>
    <div class="pay-row">
      <span class="pay-icon">UPI</span><span class="pay-icon">Visa</span><span class="pay-icon">MC</span><span class="pay-icon">NetBanking</span><span class="pay-icon">COD</span>
    </div>
  </div>
</form>
{% else %}
<div class="cart-layout" style="display:flex; justify-content:center;">
  <div class="empty-cart" id="empty-cart" style="display:flex; padding: 60px 20px;">
    <div class="empty-icon">&#128722;</div>
    <div class="empty-title">Your cart is empty</div>
    <div class="empty-sub">Looks like you haven't added anything yet.<br>Explore our handcrafted blouse collection!</div>
    <a href="/collections/all" class="btn-shop">SHOP NOW</a>
  </div>
</div>
{% endif %}

<section class="recently-section">
  <div class="rs-title">You May Also Like</div>
  <div class="rs-grid">
    {% for product in collections.all.products limit: 4 %}
      <div class="rs-card" onclick="window.location.href='{{ product.url }}'">
        <div class="rs-img"><img src="{{ product.featured_image | img_url: '400x' }}" alt="{{ product.title | escape }}"></div>
        <div class="rs-info">
          <div class="rs-name">{{ product.title }}</div>
          <div class="rs-price-row">
            <span class="rs-price">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
              <span class="rs-old">{{ product.compare_at_price | money }}</span>
            {% endif %}
          </div>
          <form action="/cart/add" method="post" enctype="multipart/form-data">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <button type="submit" class="rs-add" style="pointer-events:all;">ADD TO CART</button>
          </form>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
