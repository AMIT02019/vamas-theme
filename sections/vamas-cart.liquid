{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}
<div class="breadcrumb">
  <a href="index.html">Home</a><span>&#8250;</span><span>My Cart</span>
</div>

<div class="cart-page-header">
  <div style="display:flex;align-items:center;">
    <span class="cart-page-title">My Cart</span>
    <span class="cart-count-badge" id="cart-count-badge">0 items</span>
  </div>
  <a href="collection.html" class="continue-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Continue Shopping
  </a>
</div>

<div class="cart-layout">

  <div id="cart-left">
    <div class="free-del-box" id="free-del-box">
      <div class="fdel-top">
        <div class="fdel-label">Add <strong id="fdel-amount">Rs.—</strong> more for free delivery!</div>
      </div>
      <div class="fdel-track"><div class="fdel-fill" id="fdel-fill" style="width:0%"></div></div>
    </div>
    <div class="fdel-success" id="fdel-success" style="display:none;">&#127881; You've unlocked <strong>FREE delivery!</strong></div>

    <div class="cart-items-wrap" id="cart-items-wrap">
      <div class="cart-items-head">
        <div>PRODUCT</div><div>PRICE</div><div>QUANTITY</div><div style="text-align:right;">SUBTOTAL</div><div></div>
      </div>
      <div id="cart-items-body"></div>
    </div>

    <div class="empty-cart" id="empty-cart">
      <div class="empty-icon">&#128722;</div>
      <div class="empty-title">Your cart is empty</div>
      <div class="empty-sub">Looks like you haven't added anything yet.<br>Explore our handcrafted blouse collection!</div>
      <a href="collection.html" class="btn-shop">SHOP NOW</a>
    </div>
  </div>

  <div class="order-summary" id="order-summary-panel">
    <div class="os-title">ORDER SUMMARY</div>

    <div class="coupon-form">
      <input class="coupon-input" id="coupon-input" type="text" placeholder="Enter coupon code" autocomplete="off">
      <button class="coupon-btn" id="coupon-apply-btn" onclick="applyCoupon()">APPLY</button>
    </div>
    <div class="coupon-result" id="coupon-result"></div>
    <div class="applied-coupon" id="applied-coupon">
      <span class="applied-tag" id="applied-tag"></span>
      <button class="remove-coupon" onclick="removeCoupon()">Remove</button>
    </div>

    <div class="os-row"><span>MRP Total (<span id="os-item-count">0 items</span>)</span><span id="os-mrp">Rs.0</span></div>
    <div class="os-row green"><span>Product Discount</span><span id="os-discount">− Rs.0</span></div>
    <div class="os-row green" id="coupon-row" style="display:none;"><span>Coupon Discount</span><span id="os-coupon-discount"></span></div>
    <div class="os-row"><span>Delivery Charges</span><span id="os-delivery">FREE</span></div>
    <div class="os-divider"></div>
    <div class="os-total"><span>TOTAL PAYABLE</span><span id="os-total">Rs.0</span></div>
    <div class="os-saving" id="os-saving" style="display:none;">&#127881; You're saving <strong id="os-saving-amt">Rs.0</strong> on this order!</div>

    <button class="btn-checkout" onclick="window.location.href='checkout.html'">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      PROCEED TO CHECKOUT
    </button>
    <button class="btn-continue" onclick="window.location.href='collection.html'">Continue Shopping</button>

    <div class="trust-mini">
      <div class="tm-item"><svg class="tm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>100% Secure Checkout</div>
      <div class="tm-item"><svg class="tm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg>7-Day Easy Returns</div>
      <div class="tm-item"><svg class="tm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>Ships in 2–3 Business Days</div>
      <div class="tm-item"><svg class="tm-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Handcrafted &amp; Authentic</div>
    </div>
    <div class="pay-row">
      <span class="pay-icon">UPI</span><span class="pay-icon">Visa</span><span class="pay-icon">MC</span><span class="pay-icon">NetBanking</span><span class="pay-icon">COD</span>
    </div>
  </div>

</div>

<section class="recently-section">
  <div class="rs-title">You May Also Like</div>
  <div class="rs-grid">
    <div class="rs-card" onclick="window.location.href='product.html'">
      <div class="rs-img"><img src="assets/prod-cobalt.jpg" alt="Velvet Zardozi Blouse"></div>
      <div class="rs-info"><div class="rs-name">Velvet Zardozi Blouse</div><div class="rs-type">Velvet · Zardozi Work</div><div class="rs-price-row"><span class="rs-price">Rs.1,599</span><span class="rs-old">Rs.2,399</span><span class="rs-off">33% off</span></div><button class="rs-add" onclick="quickAdd(event,this,'Velvet Zardozi Blouse','Velvet · Zardozi Work',1599,2399,'assets/prod-cobalt.jpg')">ADD TO CART</button></div>
    </div>
    <div class="rs-card" onclick="window.location.href='product.html'">
      <div class="rs-img"><img src="assets/prod-green2.jpg" alt="Gota Patti Blouse"></div>
      <div class="rs-info"><div class="rs-name">Gota Patti Blouse</div><div class="rs-type">Silk · Gota Patti Work</div><div class="rs-price-row"><span class="rs-price">Rs.999</span><span class="rs-old">Rs.1,599</span><span class="rs-off">38% off</span></div><button class="rs-add" onclick="quickAdd(event,this,'Gota Patti Blouse','Silk · Gota Patti Work',999,1599,'assets/prod-green2.jpg')">ADD TO CART</button></div>
    </div>
    <div class="rs-card" onclick="window.location.href='product.html'">
      <div class="rs-img"><img src="assets/prod-maroon2.jpg" alt="Chikankari Lucknowi Blouse"></div>
      <div class="rs-info"><div class="rs-name">Chikankari Lucknowi Blouse</div><div class="rs-type">Cotton Silk · Chikankari</div><div class="rs-price-row"><span class="rs-price">Rs.1,099</span><span class="rs-old">Rs.1,799</span><span class="rs-off">39% off</span></div><button class="rs-add" onclick="quickAdd(event,this,'Chikankari Lucknowi Blouse','Cotton Silk · Chikankari',1099,1799,'assets/prod-maroon2.jpg')">ADD TO CART</button></div>
    </div>
    <div class="rs-card" onclick="window.location.href='product.html'">
      <div class="rs-img"><img src="assets/prod-darkmaroon.jpg" alt="Chanderi Silk Blouse"></div>
      <div class="rs-info"><div class="rs-name">Chanderi Silk Blouse</div><div class="rs-type">Chanderi · Block Print</div><div class="rs-price-row"><span class="rs-price">Rs.1,199</span><span class="rs-old">Rs.1,899</span><span class="rs-off">37% off</span></div><button class="rs-add" onclick="quickAdd(event,this,'Chanderi Silk Blouse','Chanderi · Block Print',1199,1899,'assets/prod-darkmaroon.jpg')">ADD TO CART</button></div>
    </div>
  </div>
</section>

<div class="undo-toast" id="undo-toast">
  <span id="undo-msg">Item removed</span>
  <button class="undo-btn" id="undo-btn">UNDO</button>
</div>

<div id="site-footer"></div>
<div class="wp-float">W</div>

