{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

<div class="vamas-cart-breadcrumb">
  <a href="/">{{ section.settings.breadcrumb_home | default: 'Home' }}</a><span>&#8250;</span><span>{{ section.settings.page_title | default: 'My Cart' }}</span>
</div>

<div class="vamas-cart-page-header">
  <div style="display:flex;align-items:center;">
    <span class="vamas-cart-page-title">{{ section.settings.page_title | default: 'My Cart' }}</span>
    <span class="vamas-cart-count-badge" id="vamas-cart-count-badge" data-items-label="{{ section.settings.items_label | default: 'items' }}">{{ cart.item_count }} {{ section.settings.items_label | default: 'items' }}</span>
  </div>
  <a href="/collections/all" class="vamas-cart-continue-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    {{ section.settings.continue_shopping_text | default: 'Continue Shopping' }}
  </a>
</div>

{% if cart.item_count > 0 %}
<div class="vamas-cart-layout">

  <div id="vamas-cart-left">
    {% if section.settings.show_free_delivery_bar %}
      {% assign threshold = section.settings.free_delivery_threshold | times: 100 %}
      {% assign remaining = threshold | minus: cart.total_price %}
      <div class="vamas-cart-free-del-box" id="vamas-cart-fdel-box" data-threshold="{{ threshold }}" {% if remaining <= 0 %}style="display:none;"{% endif %}>
        <div class="vamas-cart-fdel-top">
          <div class="vamas-cart-fdel-label">{{ section.settings.free_delivery_prefix | default: 'Add' }} <strong id="vamas-cart-fdel-amount">{{ remaining | money }}</strong> {{ section.settings.free_delivery_suffix | default: 'more for free delivery!' }}</div>
        </div>
        <div class="vamas-cart-fdel-track"><div class="vamas-cart-fdel-fill" id="vamas-cart-fdel-fill" style="width:{{ cart.total_price | times: 100.0 | divided_by: threshold | at_most: 100 }}%"></div></div>
      </div>
      <div class="vamas-cart-fdel-success" id="vamas-cart-fdel-success" {% if remaining > 0 %}style="display:none;"{% endif %}>&#127881; {{ section.settings.free_delivery_unlocked | default: "You've unlocked FREE delivery!" }}</div>
    {% endif %}

    {% form 'cart', cart, id: 'vamas-cart-form' %}
      <div class="vamas-cart-items-wrap">
        <div class="vamas-cart-items-head">
          <div>{{ section.settings.col_product | default: 'PRODUCT' }}</div>
          <div>{{ section.settings.col_price | default: 'PRICE' }}</div>
          <div>{{ section.settings.col_qty | default: 'QUANTITY' }}</div>
          <div style="text-align:right;">{{ section.settings.col_subtotal | default: 'SUBTOTAL' }}</div>
          <div></div>
        </div>
        <div id="vamas-cart-items-body">
          {% for item in cart.items %}
            <div class="vamas-cart-item" data-line="{{ forloop.index }}" data-key="{{ item.key }}">
              <div class="vamas-cart-ci-product">
                <a href="{{ item.url }}" class="vamas-cart-ci-img">
                  {% if item.image %}<img src="{{ item.image | img_url: '160x192', crop: 'center' }}" alt="{{ item.image.alt | escape | default: item.product.title }}" loading="lazy">{% endif %}
                </a>
                <div>
                  <a href="{{ item.url }}" style="text-decoration:none;"><div class="vamas-cart-ci-name">{{ item.product.title }}</div></a>
                  <div class="vamas-cart-ci-type">{{ item.product.type }}</div>
                  {% if item.variant.title != 'Default Title' %}
                    <div class="vamas-cart-ci-attrs">
                      {% for option in item.options_with_values %}
                        <span class="vamas-cart-ci-attr">{{ option.name }}: {{ option.value }}</span>
                      {% endfor %}
                    </div>
                  {% endif %}
                  <div class="vamas-cart-ci-actions">
                    <button type="button" class="vamas-cart-ci-action-btn vamas-cart-remove-btn" data-line="{{ forloop.index }}">{{ section.settings.remove_text | default: 'Remove' }}</button>
                  </div>
                </div>
              </div>
              <div class="vamas-cart-ci-price">
                {{ item.final_price | money }}
                {% if item.original_price > item.final_price %}
                  <div class="vamas-cart-ci-orig">{{ item.original_price | money }}</div>
                {% endif %}
              </div>
              <div class="vamas-cart-ci-qty">
                <div class="vamas-cart-qty-control">
                  <button type="button" class="vamas-cart-qty-btn vamas-cart-qty-minus" data-line="{{ forloop.index }}">&#8722;</button>
                  <input type="number" class="vamas-cart-qty-num" name="updates[{{ forloop.index0 }}]" data-line="{{ forloop.index }}" value="{{ item.quantity }}" min="0">
                  <button type="button" class="vamas-cart-qty-btn vamas-cart-qty-plus" data-line="{{ forloop.index }}">&#43;</button>
                </div>
              </div>
              <div class="vamas-cart-ci-subtotal">{{ item.final_line_price | money }}</div>
              <div class="vamas-cart-ci-remove">
                <button type="button" class="vamas-cart-ci-remove-btn" data-line="{{ forloop.index }}" aria-label="Remove item">&times;</button>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="vamas-cart-order-summary" id="vamas-order-summary-panel">
        <div class="vamas-cart-os-title">{{ section.settings.summary_title | default: 'ORDER SUMMARY' }}</div>

        {% if section.settings.show_discount_field %}
          <div class="vamas-cart-coupon-form">
            <input class="vamas-cart-coupon-input" id="vamas-coupon-input" type="text" placeholder="{{ section.settings.coupon_placeholder | default: 'Enter coupon code' }}" autocomplete="off">
            <button class="vamas-cart-coupon-btn" type="button" id="vamas-coupon-apply-btn" data-cart-url="{{ routes.cart_url }}">{{ section.settings.apply_text | default: 'APPLY' }}</button>
          </div>
          <div class="vamas-cart-coupon-hint">{{ section.settings.coupon_hint | default: 'Discount codes are applied at checkout.' }}</div>
          {% if cart.cart_level_discount_applications.size > 0 %}
            {% for discount in cart.cart_level_discount_applications %}
              <div class="vamas-cart-applied-coupon show">
                <span class="vamas-cart-applied-tag">{{ discount.title }} (-{{ discount.total_allocated_amount | money }})</span>
              </div>
            {% endfor %}
          {% endif %}
        {% endif %}

        <div class="vamas-cart-os-row"><span>{{ section.settings.subtotal_label | default: 'Subtotal' }} (<span id="vamas-cart-item-count-text">{{ cart.item_count }} {{ section.settings.items_label | default: 'items' }}</span>)</span><span id="vamas-cart-subtotal-value">{{ cart.original_total_price | money }}</span></div>
        <div class="vamas-cart-os-row vamas-cart-os-row--green" id="vamas-cart-discount-row" {% unless cart.total_discount > 0 %}style="display:none;"{% endunless %}><span>{{ section.settings.discount_label | default: 'Discount' }}</span><span id="vamas-cart-discount-value">&minus; {{ cart.total_discount | money }}</span></div>
        <div class="vamas-cart-os-row"><span>{{ section.settings.delivery_label | default: 'Delivery Charges' }}</span><span>{{ section.settings.delivery_value | default: 'FREE' }}</span></div>
        <div class="vamas-cart-os-divider"></div>
        <div class="vamas-cart-os-total"><span>{{ section.settings.total_label | default: 'TOTAL PAYABLE' }}</span><span id="vamas-cart-total-value">{{ cart.total_price | money }}</span></div>

        <button type="submit" name="checkout" class="vamas-cart-btn-checkout">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {{ section.settings.checkout_text | default: 'PROCEED TO CHECKOUT' }}
        </button>
        <a href="/collections/all" class="vamas-cart-btn-continue">{{ section.settings.continue_shopping_text | default: 'Continue Shopping' }}</a>

        {% assign trust_blocks = section.blocks | where: 'type', 'trust_line' %}
        {% if trust_blocks.size > 0 %}
          <div class="vamas-cart-trust-mini">
            {% for block in section.blocks %}
              {% if block.type == 'trust_line' %}
                <div class="vamas-cart-tm-item" {{ block.shopify_attributes }}>{{ block.settings.icon }} {{ block.settings.label }}</div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
        {% if section.settings.show_payment_row %}
          <div class="vamas-cart-pay-row">
            {% assign pay_methods = section.settings.payment_methods | default: 'UPI, Visa, MC, NetBanking, COD' | split: ',' %}
            {% for method in pay_methods %}<span class="vamas-cart-pay-icon">{{ method | strip }}</span>{% endfor %}
          </div>
        {% endif %}
      </div>
    {% endform %}
  </div>
</div>

{% comment %} ── You may also like ── {% endcomment %}
{% if section.settings.show_recommendations %}
  {% comment %} Shopify's recommendations endpoint requires a product_id for context;
       the cart has no single "current product", so the most recently added line
       item is used as a reasonable proxy. {% endcomment %}
  <div id="vamas-cart-related" data-url="{{ routes.product_recommendations_url }}" data-product-id="{{ cart.items.last.product_id }}"></div>
{% endif %}

{% else %}
  {% comment %} ── Empty cart state ── {% endcomment %}
  <div class="vamas-cart-empty">
    <div class="vamas-cart-empty__icon">&#128722;</div>
    <div class="vamas-cart-empty__title">{{ section.settings.empty_title | default: 'Your cart is empty' }}</div>
    <div class="vamas-cart-empty__sub">{{ section.settings.empty_sub | default: "Looks like you haven't added anything yet. Explore our handcrafted blouse collection!" }}</div>
    <a href="/collections/all" class="vamas-cart-btn-shop">{{ section.settings.empty_cta_text | default: 'SHOP NOW' }}</a>
  </div>
{% endif %}

{% schema %}
{
  "name": "Vamas Cart",
  "settings": [
    { "type": "text", "id": "breadcrumb_home", "label": "Breadcrumb home label", "default": "Home" },
    { "type": "text", "id": "page_title", "label": "Page title", "default": "My Cart" },
    { "type": "text", "id": "items_label", "label": "\"items\" label", "default": "items" },
    { "type": "text", "id": "continue_shopping_text", "label": "Continue shopping text", "default": "Continue Shopping" },
    { "type": "header", "content": "Free delivery bar" },
    { "type": "checkbox", "id": "show_free_delivery_bar", "label": "Show free delivery progress bar", "default": true },
    { "type": "number", "id": "free_delivery_threshold", "label": "Free delivery threshold (₹)", "default": 999 },
    { "type": "text", "id": "free_delivery_prefix", "label": "Prefix text", "default": "Add" },
    { "type": "text", "id": "free_delivery_suffix", "label": "Suffix text", "default": "more for free delivery!" },
    { "type": "text", "id": "free_delivery_unlocked", "label": "Unlocked message", "default": "You've unlocked FREE delivery!" },
    { "type": "header", "content": "Table labels" },
    { "type": "text", "id": "col_product", "label": "Column: product", "default": "PRODUCT" },
    { "type": "text", "id": "col_price", "label": "Column: price", "default": "PRICE" },
    { "type": "text", "id": "col_qty", "label": "Column: quantity", "default": "QUANTITY" },
    { "type": "text", "id": "col_subtotal", "label": "Column: subtotal", "default": "SUBTOTAL" },
    { "type": "text", "id": "remove_text", "label": "Remove link text", "default": "Remove" },
    { "type": "header", "content": "Order summary" },
    { "type": "text", "id": "summary_title", "label": "Summary title", "default": "ORDER SUMMARY" },
    { "type": "checkbox", "id": "show_discount_field", "label": "Show discount code field", "default": true },
    { "type": "text", "id": "coupon_placeholder", "label": "Coupon input placeholder", "default": "Enter coupon code" },
    { "type": "text", "id": "apply_text", "label": "Apply button text", "default": "APPLY" },
    { "type": "text", "id": "coupon_hint", "label": "Coupon hint text", "default": "Discount codes are applied at checkout." },
    { "type": "text", "id": "subtotal_label", "label": "Subtotal label", "default": "Subtotal" },
    { "type": "text", "id": "discount_label", "label": "Discount label", "default": "Discount" },
    { "type": "text", "id": "delivery_label", "label": "Delivery label", "default": "Delivery Charges" },
    { "type": "text", "id": "delivery_value", "label": "Delivery value", "default": "FREE" },
    { "type": "text", "id": "total_label", "label": "Total label", "default": "TOTAL PAYABLE" },
    { "type": "text", "id": "checkout_text", "label": "Checkout button text", "default": "PROCEED TO CHECKOUT" },
    { "type": "checkbox", "id": "show_payment_row", "label": "Show payment icons row", "default": true },
    { "type": "text", "id": "payment_methods", "label": "Payment methods (comma separated)", "default": "UPI, Visa, MC, NetBanking, COD" },
    { "type": "checkbox", "id": "show_recommendations", "label": "Show \"You may also like\"", "default": true },
    { "type": "header", "content": "Empty cart" },
    { "type": "text", "id": "empty_title", "label": "Empty title", "default": "Your cart is empty" },
    { "type": "textarea", "id": "empty_sub", "label": "Empty subtext", "default": "Looks like you haven't added anything yet. Explore our handcrafted blouse collection!" },
    { "type": "text", "id": "empty_cta_text", "label": "Empty CTA button text", "default": "SHOP NOW" }
  ],
  "blocks": [
    {
      "type": "trust_line",
      "name": "Trust Line",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🔒" },
        { "type": "text", "id": "label", "label": "Label", "default": "100% Secure Checkout" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vamas Cart",
      "blocks": [
        { "type": "trust_line", "settings": { "icon": "🔒", "label": "100% Secure Checkout" } },
        { "type": "trust_line", "settings": { "icon": "↺", "label": "7-Day Easy Returns" } },
        { "type": "trust_line", "settings": { "icon": "📦", "label": "Ships in 2-3 Business Days" } },
        { "type": "trust_line", "settings": { "icon": "🧵", "label": "Handcrafted & Authentic" } }
      ]
    }
  ]
}
{% endschema %}
