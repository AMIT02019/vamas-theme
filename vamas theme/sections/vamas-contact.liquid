{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

{% comment %} ── Hero ─────────────────────────────── {% endcomment %}
<section class="vamas-contact-hero">
  <p class="vamas-contact-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
  <h1 class="vamas-contact-hero__title">{{ section.settings.hero_title }}</h1>
  {% if section.settings.hero_sub != blank %}
    <p class="vamas-contact-hero__sub">{{ section.settings.hero_sub }}</p>
  {% endif %}
</section>

{% comment %} ── Contact Grid: Form + Info Cards ──── {% endcomment %}
<section class="vamas-contact-section">
  <div class="vamas-contact-grid">

    {% comment %} Form — mapped to Shopify's native 'contact' form.
         Shopify's contact form only supports contact[name], contact[email],
         contact[phone] and contact[body] natively — it has no "subject" field.
         The Subject dropdown below is kept for UX parity with contact.html;
         a small inline script prefixes "Subject: <value>" onto the message
         body just before submit, so the chosen subject still reaches the
         store owner inside contact[body] without needing a metafield. ── {% endcomment %}
    <div class="vamas-contact-form">
      <div class="vamas-contact-form__title">{{ section.settings.form_title }}</div>
      <div class="vamas-contact-form__sub">{{ section.settings.form_sub }}</div>

      {% form 'contact', id: 'vamas-contact-form' %}
        {% if form.posted_successfully? %}
          <div class="vamas-contact-form__success vamas-contact-form__success--visible">
            {{ section.settings.success_message }}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="vamas-contact-form__error">
            <ul>
              {% for field in form.errors %}
                <li>
                  {% if field == 'form' %}
                    {{ form.errors.messages[field] }}
                  {% else %}
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        <div class="vamas-contact-form__group">
          <label for="ContactFormName">{{ section.settings.label_name }}</label>
          <input type="text" id="ContactFormName" name="contact[name]" placeholder="{{ section.settings.placeholder_name }}"
                 value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" required>
        </div>
        <div class="vamas-contact-form__group">
          <label for="ContactFormEmail">{{ section.settings.label_email }}</label>
          <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="{{ section.settings.placeholder_email }}"
                 autocomplete="email" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required>
        </div>
        <div class="vamas-contact-form__group">
          <label for="ContactFormPhone">{{ section.settings.label_phone }}</label>
          <input type="tel" id="ContactFormPhone" name="contact[phone]" placeholder="{{ section.settings.placeholder_phone }}"
                 autocomplete="tel" value="{% if form.phone %}{{ form.phone }}{% endif %}">
        </div>
        <div class="vamas-contact-form__group">
          <label for="ContactFormSubject">{{ section.settings.label_subject }}</label>
          <select id="ContactFormSubject" name="contact_subject">
            <option value="" disabled selected>{{ section.settings.subject_placeholder }}</option>
            <option value="{{ section.settings.subject_option_1 }}">{{ section.settings.subject_option_1 }}</option>
            <option value="{{ section.settings.subject_option_2 }}">{{ section.settings.subject_option_2 }}</option>
            <option value="{{ section.settings.subject_option_3 }}">{{ section.settings.subject_option_3 }}</option>
            <option value="{{ section.settings.subject_option_4 }}">{{ section.settings.subject_option_4 }}</option>
          </select>
        </div>
        <div class="vamas-contact-form__group">
          <label for="ContactFormMessage">{{ section.settings.label_message }}</label>
          <textarea id="ContactFormMessage" name="contact[body]" rows="5" placeholder="{{ section.settings.placeholder_message }}" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
        <button type="submit" class="vamas-contact-form__submit">{{ section.settings.submit_text }}</button>
      {% endform %}
    </div>

    {% comment %} ── Info Cards ────────────────────── {% endcomment %}
    <div class="vamas-contact-info">
      {% for block in section.blocks %}
        {% if block.type == 'contact_info' %}
          <div class="vamas-contact-info__card" {{ block.shopify_attributes }}>
            <div class="vamas-contact-info__icon">
              {% case block.settings.icon %}
                {% when 'phone' %}
                  <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.64 3.38 2 2 0 0 1 3.62 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.81a16 16 0 0 0 6.13 6.13l.95-.95a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {% when 'email' %}
                  <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                {% when 'social' %}
                  <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
                {% else %}
                  <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {% endcase %}
            </div>
            <div class="vamas-contact-info__head">{{ block.settings.heading }}</div>
            <div class="vamas-contact-info__line">
              {% if block.settings.link_url != blank %}
                <a href="{{ block.settings.link_url }}">{{ block.settings.line1 }}</a>
              {% else %}
                {{ block.settings.line1 }}
              {% endif %}
              {% if block.settings.line2 != blank %}<br>{{ block.settings.line2 }}{% endif %}
            </div>
            {% if block.settings.icon == 'social' %}
              <div class="vamas-contact-info__social-row">
                {% if block.settings.instagram_url != blank %}
                  <a href="{{ block.settings.instagram_url }}" class="vamas-contact-info__soc-btn" title="Instagram">
                    <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
                  </a>
                {% endif %}
                {% if block.settings.facebook_url != blank %}
                  <a href="{{ block.settings.facebook_url }}" class="vamas-contact-info__soc-btn" title="Facebook">
                    <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                  </a>
                {% endif %}
                {% if block.settings.whatsapp_url != blank %}
                  <a href="{{ block.settings.whatsapp_url }}" class="vamas-contact-info__soc-btn" title="WhatsApp">
                    <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function(){
  var form = document.getElementById('vamas-contact-form');
  if(!form) return;
  form.addEventListener('submit', function(){
    var subjectEl = form.querySelector('[name="contact_subject"]');
    var bodyEl = form.querySelector('[name="contact[body]"]');
    if(subjectEl && bodyEl && subjectEl.value){
      bodyEl.value = 'Subject: ' + subjectEl.value + '\n\n' + bodyEl.value;
    }
  });
})();
</script>

{% comment %} ── FAQ ──────────────────────────────── {% endcomment %}
{% assign faq_blocks = section.blocks | where: 'type', 'faq' %}
{% if faq_blocks.size > 0 %}
<section class="vamas-contact-faq">
  <div class="vamas-contact-faq__header">
    <p class="vamas-contact-faq__eyebrow">{{ section.settings.faq_eyebrow }}</p>
    <div class="vamas-contact-faq__title">{{ section.settings.faq_heading }}</div>
    {% if section.settings.faq_subtext != blank %}<p class="vamas-contact-faq__sub">{{ section.settings.faq_subtext }}</p>{% endif %}
  </div>
  <div class="vamas-contact-faq__list">
    {% for block in section.blocks %}
      {% if block.type == 'faq' %}
        <div class="vamas-contact-faq__item" {{ block.shopify_attributes }}>
          <button class="vamas-contact-faq__question" type="button">
            {{ block.settings.question }}
            <span class="vamas-contact-faq__arrow"><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></span>
          </button>
          <div class="vamas-contact-faq__answer">{{ block.settings.answer }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<script>
(function(){
  document.querySelectorAll('.vamas-contact-faq__question').forEach(function(btn){
    btn.addEventListener('click', function(){
      var item = btn.closest('.vamas-contact-faq__item');
      var isOpen = item.classList.contains('vamas-contact-faq__item--open');
      document.querySelectorAll('.vamas-contact-faq__item').forEach(function(i){ i.classList.remove('vamas-contact-faq__item--open'); });
      if(!isOpen){ item.classList.add('vamas-contact-faq__item--open'); }
    });
  });
})();
</script>
{% endif %}

{% comment %} ── Map ──────────────────────────────── {% endcomment %}
<section class="vamas-contact-map">
  <div class="vamas-contact-map__inner">
    <div class="vamas-contact-map__placeholder">
      <div class="vamas-contact-map__pin">
        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
      <div class="vamas-contact-map__label">{{ section.settings.map_label }}</div>
      <div class="vamas-contact-map__addr">{{ section.settings.map_address }}</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vamas Contact",
  "tag": "div",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow Text", "default": "VAMAS · JAIPUR" },
    { "type": "text", "id": "hero_title", "label": "Title", "default": "Get In Touch" },
    { "type": "text", "id": "hero_sub", "label": "Subtext", "default": "We'd love to hear from you" },

    { "type": "header", "content": "Form" },
    { "type": "text", "id": "form_title", "label": "Form Title", "default": "Send Us a Message" },
    { "type": "text", "id": "form_sub", "label": "Form Subtext", "default": "Fill in the form and we'll get back to you shortly." },
    { "type": "text", "id": "label_name", "label": "Name Field Label", "default": "FULL NAME" },
    { "type": "text", "id": "placeholder_name", "label": "Name Field Placeholder", "default": "Your full name" },
    { "type": "text", "id": "label_email", "label": "Email Field Label", "default": "EMAIL ADDRESS" },
    { "type": "text", "id": "placeholder_email", "label": "Email Field Placeholder", "default": "your@email.com" },
    { "type": "text", "id": "label_phone", "label": "Phone Field Label", "default": "PHONE NUMBER" },
    { "type": "text", "id": "placeholder_phone", "label": "Phone Field Placeholder", "default": "+91 XXXXX XXXXX" },
    { "type": "text", "id": "label_subject", "label": "Subject Field Label", "default": "SUBJECT" },
    { "type": "text", "id": "subject_placeholder", "label": "Subject Placeholder Option", "default": "Select a subject" },
    { "type": "text", "id": "subject_option_1", "label": "Subject Option 1", "default": "General Inquiry" },
    { "type": "text", "id": "subject_option_2", "label": "Subject Option 2", "default": "Order Issue" },
    { "type": "text", "id": "subject_option_3", "label": "Subject Option 3", "default": "Custom Order" },
    { "type": "text", "id": "subject_option_4", "label": "Subject Option 4", "default": "Wholesale" },
    { "type": "text", "id": "label_message", "label": "Message Field Label", "default": "MESSAGE" },
    { "type": "text", "id": "placeholder_message", "label": "Message Field Placeholder", "default": "Tell us how we can help you..." },
    { "type": "text", "id": "submit_text", "label": "Submit Button Text", "default": "SEND MESSAGE" },
    { "type": "text", "id": "success_message", "label": "Success Message", "default": "Thank you! We'll get back to you within 24 hours." },

    { "type": "header", "content": "FAQ" },
    { "type": "text", "id": "faq_eyebrow", "label": "Eyebrow Text", "default": "GOT QUESTIONS?" },
    { "type": "textarea", "id": "faq_heading", "label": "Heading", "info": "Use <span>text</span> to highlight a word in gold.", "default": "Frequently Asked <span>Questions</span>" },
    { "type": "text", "id": "faq_subtext", "label": "Subtext", "default": "Quick answers to what our customers ask most" },

    { "type": "header", "content": "Map" },
    { "type": "text", "id": "map_label", "label": "Map Label", "default": "Find Us" },
    { "type": "text", "id": "map_address", "label": "Map Address", "default": "123, Artisan Lane, Jaipur, Rajasthan 302001" }
  ],
  "blocks": [
    {
      "type": "contact_info",
      "name": "Contact Info Card",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
            { "value": "location", "label": "Location" },
            { "value": "phone", "label": "Phone" },
            { "value": "email", "label": "Email" },
            { "value": "social", "label": "Social" }
          ], "default": "location" },
        { "type": "text", "id": "heading", "label": "Card Heading", "default": "OUR STUDIO" },
        { "type": "text", "id": "line1", "label": "Line 1", "default": "123, Artisan Lane" },
        { "type": "text", "id": "line2", "label": "Line 2", "default": "Jaipur, Rajasthan 302001" },
        { "type": "url", "id": "link_url", "label": "Link URL (optional, e.g. tel: or mailto:)" },
        { "type": "header", "content": "Social links (used when icon is Social)" },
        { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
        { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
        { "type": "url", "id": "whatsapp_url", "label": "WhatsApp URL" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does delivery take?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>We deliver pan-India within 3-5 business days.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vamas Contact",
      "blocks": [
        { "type": "contact_info", "settings": { "icon": "location", "heading": "OUR STUDIO", "line1": "123, Artisan Lane", "line2": "Jaipur, Rajasthan 302001" } },
        { "type": "contact_info", "settings": { "icon": "phone", "heading": "CALL US", "line1": "+91 98765 43210", "line2": "Mon-Sat: 10am - 6pm", "link_url": "tel:+919876543210" } },
        { "type": "contact_info", "settings": { "icon": "email", "heading": "EMAIL US", "line1": "support@vamas.in", "line2": "Response within 24 hours", "link_url": "mailto:support@vamas.in" } },
        { "type": "contact_info", "settings": { "icon": "social", "heading": "FOLLOW US", "line1": "@vamas.official", "instagram_url": "#", "facebook_url": "#", "whatsapp_url": "https://wa.me/919876543210" } },
        { "type": "faq", "settings": { "question": "How long does delivery take?", "answer": "<p>We deliver pan-India within 3-5 business days. For remote areas, delivery may take 7-10 business days. You'll receive a tracking link via SMS and email once your order is dispatched.</p>" } },
        { "type": "faq", "settings": { "question": "Do you offer custom sizing?", "answer": "<p>Yes! We offer custom sizing at no extra charge. Simply share your measurements in the order notes at checkout and our tailors will craft your blouse to your exact fit.</p>" } },
        { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "<p>We offer 7-day hassle-free returns on all unworn items in original condition with tags intact. Simply initiate a return from your order page or contact our support team and we'll arrange a free pickup.</p>" } },
        { "type": "faq", "settings": { "question": "How can I track my order?", "answer": "<p>Once your order is dispatched, a tracking link will be sent to your registered mobile number via SMS and to your email address. You can also track your order from the \"My Orders\" section on our website.</p>" } },
        { "type": "faq", "settings": { "question": "Do you offer wholesale?", "answer": "<p>Yes, we offer wholesale pricing for orders above 50 pieces. Please write to us at <a href=\"mailto:wholesale@vamas.in\">wholesale@vamas.in</a> with your requirements and we'll get back to you with our bulk pricing catalog.</p>" } }
      ]
    }
  ]
}
{% endschema %}
